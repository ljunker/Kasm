{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "KASM",
  "scopeName": "source.kasm",
  "patterns": [
    {
      "include": "#strings"
    },
    {
      "include": "#comments"
    },
    {
      "include": "#labels"
    },
    {
      "include": "#instructions"
    },
    {
      "include": "#directives"
    },
    {
      "include": "#registers"
    },
    {
      "include": "#numbers"
    }
  ],
  "repository": {
    "strings": {
      "name": "string.quoted.double.kasm",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.kasm",
          "match": "\\\\(?:[0nrt\"\\\\])"
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.semicolon.kasm",
          "match": ";.*$"
        }
      ]
    },
    "labels": {
      "patterns": [
        {
          "name": "entity.name.label.kasm",
          "match": "^\\s*([A-Za-z_][A-Za-z0-9_]*)(:)",
          "captures": {
            "1": {
              "name": "entity.name.label.kasm"
            },
            "2": {
              "name": "punctuation.separator.label.kasm"
            }
          }
        }
      ]
    },
    "instructions": {
      "patterns": [
        {
          "name": "keyword.instruction.kasm",
          "match": "\\b(?i:MOV|MOVA|ADD|ADDI|SUB|SUBI|INC|DEC|MUL|DIV|MOD|NEG|AND|OR|XOR|NOT|CMP|JMP|JZ|JNZ|JE|JNE|JG|JGE|JL|JLE|LOAD|STORE|PUSH|POP|CALL|RET|CLR|NOP|PRINT|PRINTC|INCA|DECA|HALT)\\b"
        }
      ]
    },
    "directives": {
      "patterns": [
        {
          "name": "keyword.directive.kasm",
          "match": "(?i:\\.EQU|\\.ORG|\\.BYTE|\\.ASCII|\\.STRING|\\.INCBIN)\\b"
        }
      ]
    },
    "registers": {
      "patterns": [
        {
          "name": "variable.language.register.kasm",
          "match": "\\b(?i:R[0-3]|A[0-1])\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.kasm",
          "match": "\\b0x[0-9A-Fa-f]+\\b"
        },
        {
          "name": "constant.numeric.binary.kasm",
          "match": "\\b0b[01]+\\b"
        },
        {
          "name": "constant.numeric.decimal.kasm",
          "match": "\\b\\d+\\b"
        }
      ]
    }
  }
}
