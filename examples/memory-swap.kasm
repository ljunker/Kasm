; Initialize two named cells, swap them, then print both values.
  .org 40
left:
  .byte 4
right:
  .byte 9

  CALL swap
  CALL print
  HALT

swap:
  PUSH R2
  PUSH R3
  LOAD R2, [left]
  LOAD R3, [right]
  STORE [left], R3
  STORE [right], R2
  POP R3
  POP R2
  RET

print:
  LOAD R0, [left]
  PRINT R0
  LOAD R0, [right]
  PRINT R0
  RET
